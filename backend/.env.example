## Example environment file for the backend
## Copy this to `backend/.env` and fill in real values. DO NOT commit real secrets.

# Server
PORT=3000

# Grok (x.ai) API key - used by the mobile AI chat endpoints
# Example: xai-xxxxxxxxxxxxxxxxxxxxx
GROK_API_KEY=

# Optional OpenAI key (not used by default)
OPENAI_API_KEY=

# Public backend URL the mobile/web app should call (for dev set to http://localhost:3000)
BACKEND_URL=http://localhost:3000

# Auth secret - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ---- Railway / Production ----
# Set these in the Railway dashboard Environment Variables tab (not in a file)
#
# ENVIRONMENT=production
# DATA_DIR=/data
# DATABASE_URL=file:/data/production.db   (set automatically by scripts/start if DATA_DIR is set)
# BACKEND_URL=https://<your-project>.up.railway.app
# BETTER_AUTH_SECRET=<generate with: openssl rand -hex 32>
# GROK_API_KEY=<your-grok-key>
#
# Apple Sign In (mobile)
# APPLE_CLIENT_ID=com.mylunarphase.app
# APPLE_CLIENT_SECRET=<JWT from App Store Connect>
# APPLE_BUNDLE_ID=com.mylunarphase.app
#
# Google Sign In (mobile)
# GOOGLE_CLIENT_ID=<from Google Cloud Console>
# GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
