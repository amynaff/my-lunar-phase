{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "postinstall": "bunx prisma generate && bunx prisma db push --skip-generate",
