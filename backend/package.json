    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "6",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@better-auth/expo": "^1.4.18",
    "@hono/node-server": "1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "6",
    "better-auth": "^1.4.18",
    "hono": "4.6.0",
    "tsx": "^4.21.0",
    "zod": "4.1.11"
  }
}
